# Copy to .env and fill in real values:
#   cp .env.example .env
#
# Deploy: ./scripts/deploy_web.sh
# Local Flutter web: ./scripts/run_flutter_web_local.sh

# ---------- Site ----------
PUBLIC_WEB_APP_URL=https://projecttrackertest.hku.hk
DEPLOY_ENV=testing

# ---------- App users ----------
ADMIN_EMAIL=your-admin@hku.hk

# ---------- Stack identity (host ports + Docker names) ----------
# Change these per machine / per env so test + prod can coexist.
STACK_NAME=pt-test
POSTGRES_CONTAINER=pt-test-postgres
BACKEND_CONTAINER=pt-test-backend
POSTGREST_CONTAINER=pt-test-postgrest
REST_GATEWAY_CONTAINER=pt-test-rest-gateway
NGINX_CONTAINER=pt-test-nginx
FRONTEND_CONTAINER=pt-frontend

HOST_POSTGRES_PORT=5432
HOST_BACKEND_PORT=3000
HOST_POSTGREST_PORT=3001
# Alias used by older scripts / compose gateway mapping
POSTGREST_PORT=3001

# Optional: public 80/443 via shared proxy OR this stack's frontend profile
# NGINX_HTTP_PORT is only for the optional local HTTP nginx profile
NGINX_HTTP_PORT=8080

# Derived local URLs (override if you use a non-loopback host)
LOCAL_API_BASE_URL=http://127.0.0.1:3000
LOCAL_POSTGREST_URL=http://127.0.0.1:3001
LOCAL_FILES_API_BASE=http://127.0.0.1:3000/api/files

# ---------- PostgreSQL ----------
POSTGRES_DB=project_tracker
POSTGRES_USER=project_tracker
POSTGRES_PASSWORD=change-me-use-a-long-random-password

# ---------- Backend ----------
CRON_SECRET=change-me-use-a-long-random-secret
EMAIL_SENDING_ENABLED=false
DISABLE_INTERNAL_URGENT_CRON=true

# ---------- HKU OpenID Connect ----------
SSO_ISSUER_URL=https://oidp.hku.hk/oidc
SSO_CLIENT_ID=51043fd2-d6f4-4742-8eaf-5ddc1a75c2eb
SSO_CLIENT_SECRET=change-me-paste-from-ITS
SSO_SCOPES="openid hku"
SSO_REDIRECT_URI=https://projecttrackertest.hku.hk
SSO_POST_LOGOUT_REDIRECT_URI=https://projecttrackertest.hku.hk

# ---------- PostgREST / Flutter ----------
# If a value contains # wrap in double quotes, e.g. PGRST_JWT_SECRET="abc#123"
POSTGREST_AUTHENTICATOR_PASSWORD=change-me-postgrest-authenticator-password
PGRST_JWT_SECRET=change-me-local-postgrest-jwt-secret

# ---------- SMTP ----------
SMTP_HOST=mail7.hku.hk
SMTP_PORT=25
SMTP_FROM=daaoit.ops@hku.hk
SMTP_USER=
SMTP_PASSWORD=
SMTP_SECURE=false
