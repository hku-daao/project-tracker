rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function hasStaffKey() {
      return request.auth.token.keys().hasAll(['staffKey'])
        && request.auth.token.staffKey is string
        && request.auth.token.staffKey.size() > 0;
    }

    function staffKeyClaim() {
      return request.auth.token.staffKey;
    }

    function metadataMatchesClaim(meta) {
      let k = staffKeyClaim();
      return ('m0' in meta && meta.m0 == k)
        || ('m1' in meta && meta.m1 == k)
        || ('m2' in meta && meta.m2 == k)
        || ('m3' in meta && meta.m3 == k)
        || ('m4' in meta && meta.m4 == k)
        || ('m5' in meta && meta.m5 == k)
        || ('m6' in meta && meta.m6 == k)
        || ('m7' in meta && meta.m7 == k)
        || ('m8' in meta && meta.m8 == k)
        || ('m9' in meta && meta.m9 == k);
    }

    function canRead(uploaderUid) {
      return request.auth != null && (
        request.auth.uid == uploaderUid
        || (hasStaffKey() && metadataMatchesClaim(resource.metadata))
      );
    }

    function canCreateOrUpdate(uploaderUid) {
      return request.auth != null && request.auth.uid == uploaderUid;
    }

    function canDelete(uploaderUid) {
      return request.auth != null && request.auth.uid == uploaderUid;
    }

    match /project_tracker/users/{uploaderUid}/task_attachments/{taskId}/{fileName} {
      allow read: if canRead(uploaderUid);

      allow create: if canCreateOrUpdate(uploaderUid);

      allow update: if canCreateOrUpdate(uploaderUid);

      allow delete: if canDelete(uploaderUid);
    }

    match /project_tracker/users/{uploaderUid}/subtask_attachments/{subtaskId}/{fileName} {
      allow read: if canRead(uploaderUid);

      allow create: if canCreateOrUpdate(uploaderUid);

      allow update: if canCreateOrUpdate(uploaderUid);

      allow delete: if canDelete(uploaderUid);
    }
  }
}
