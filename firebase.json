{
  "storage": {
    "rules": "storage.rules"
  },
  "hosting": [
    {
      "target": "testing",
      "public": "build/web",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "redirects": [
        {
          "source": "/favicon.ico",
          "destination": "/favicon.png?v=20260330",
          "type": 302
        }
      ],
      "rewrites": [
        { "source": "**", "destination": "/index.html" }
      ]
    },
    {
      "target": "production",
      "public": "build/web",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "redirects": [
        {
          "source": "/favicon.ico",
          "destination": "/favicon.png?v=20260330",
          "type": 302
        }
      ],
      "rewrites": [
        { "source": "**", "destination": "/index.html" }
      ]
    }
  ]
}
