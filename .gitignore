#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Local environment (never commit)
.env

# Local API keys (never commit)
secrets/*
!secrets/*.example
scripts/local_llm.env

# Local DB dump and uploaded files (never commit)
public_tables.dump
data/

# TLS for HKU test server (copy from IT POC on 147.8.203.132)
docker/nginx/ssl/*.crt
docker/nginx/ssl/*.key
docker/nginx/ssl/*.pem

# Firebase
.firebase/
# Never commit service account keys
*-sa.json
*-sa.json.json
firebase-sa*.json
firebase-sa.json.json
**/serviceAccount*.json
**/firebase-adminsdk*.json
**/*-adminsdk-*.json
**/google-services.json
**/GoogleService-Info.plist

# Supabase local tooling (avoid committing node_modules)
supabase/node_modules/

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release
