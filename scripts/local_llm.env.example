# HKU IT Vertex AI Qwen — copy to scripts/local_llm.env (gitignored)
#   cp scripts/local_llm.env.example scripts/local_llm.env
#
# Primary subscription key (sent as HTTP header `api-key`, one line, no quotes):
#   secrets/internal_llm_api_key.txt
# Use the IT "primary key" there; keep secondary key for rotation only.
#
# Rate limits (qwen/qwen3-next-80b-a3b-instruct-maas): 5 requests/min, 300/day

LOCAL_LLM_BASE_URL=https://api.hku.hk/vertexai
LOCAL_LLM_MODEL=qwen/qwen3-next-80b-a3b-instruct-maas
LOCAL_LLM_AUTH=apim

# Optional if not using secrets/internal_llm_api_key.txt
# LOCAL_LLM_API_KEY=
